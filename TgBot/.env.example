# Скопируй в .env и заполни реальными значениями (.env в .gitignore).
# Токен получай у @BotFather. НИКОГДА не коммить реальные значения.

BOT_TOKEN=PUT_BOT_TOKEN_HERE
DATABASE_URL=postgresql+asyncpg://tgbot:CHANGE_ME@localhost:5432/tgbot
ADMINS=123456789                       # chat_id админов через запятую
DONATION_URL=https://www.donationalerts.com/r/your_account
JAVA_HOST=mc.example.com
BEDROCK_HOST=bedrock.example.com

# --- Для docker-compose (deploy/) ---
# Пароль должен совпадать с тем, что в DATABASE_URL.
POSTGRES_DB=tgbot
POSTGRES_USER=tgbot
POSTGRES_PASSWORD=CHANGE_ME
