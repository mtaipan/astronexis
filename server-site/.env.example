# Скопируй в server-site/.env и заполни (.env в .gitignore).
# docker-compose и Spring (через ${...}) подхватят эти значения.

# --- БД ---
DB_NAME=server_site
DB_USERNAME=server_site
DB_PASSWORD=CHANGE_ME

# --- ЮKassa ---
# shop-id/secret-key из личного кабинета ЮKassa (Basic auth).
# webhook-token — произвольная длинная строка, та же, что в URL вебхука.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_TOKEN=

# --- Реквизиты плательщика (ПДн, для оферты) ---
PAYEE_NAME=
PAYEE_INN=
OFFER_PUBLISHED_AT=

# --- Выдача VIP по RCON (на игровой сервер) ---
# RCON_ENABLED=false → гранты копятся в очереди (vip_grants) для плагина/ручной выдачи.
RCON_ENABLED=false
RCON_HOST=127.0.0.1
RCON_PORT=25575
RCON_PASSWORD=
# %nick% %group% %days% — подставляются автоматически
RCON_VIP_COMMAND=lp user %nick% parent addtemp %group% %days%d accumulate
VIP_GROUP=VIP
VIP_DURATION_DAYS=30
